{
  "project": {
    "name": "Mnemosyne",
    "package": "mnemosyne-memory",
    "version": "3.0.0",
    "author": "Abdias J",
    "license": "MIT",
    "description": "Zero-Dependency, Sub-Millisecond AI Memory System using SQLite",
    "python": ">=3.9",
    "homepage": "https://github.com/AxDSan/mnemosyne",
    "build_system": "setuptools"
  },

  "entry_points": {
    "console_scripts": {
      "mnemosyne-install": "mnemosyne.install:install",
      "mnemosyne-uninstall": "mnemosyne.install:uninstall",
      "mnemosyne": "mnemosyne.cli:run_cli"
    },
    "mcp_server": "mnemosyne mcp [--transport stdio|sse] [--port 8080] [--bank NAME]"
  },

  "optional_dependencies": {
    "llm": ["ctransformers>=0.2.27", "llama-cpp-python>=0.2.0", "huggingface-hub>=0.20"],
    "embeddings": ["fastembed>=0.3.0"],
    "mcp": ["mcp>=1.0.0", "anyio>=4.0"],
    "all": "union of llm+embeddings+mcp",
    "dev": ["pytest>=7.0", "build", "twine"]
  },

  "modules": {
    "mnemosyne.__init__": {
      "exports": ["Mnemosyne", "remember", "recall", "get_context", "get_stats", "forget", "update", "run_mcp_server"],
      "lazy_loading": true
    },
    "mnemosyne.core.__init__": {
      "exports": ["MnemosynePlugin", "PluginManager", "LoggingPlugin", "MetricsPlugin", "FilterPlugin", "get_manager", "MemoryStream", "MemoryEvent", "EventType", "DeltaSync", "SyncCheckpoint", "MemoryCompressor", "PatternDetector", "CompressionStats", "DetectedPattern"]
    }
  },

  "classes": {
    "Mnemosyne (mnemosyne.core.memory.Mnemosyne)": {
      "description": "Native memory interface backed by BEAM architecture. Supports bank isolation.",
      "constructor": "Mnemosyne(session_id='default', db_path=None, bank=None, author_id=None, author_type=None, channel_id=None)",
      "properties": ["stream", "compressor", "patterns", "delta_sync", "plugins"],
      "methods": {
        "remember(content, source='conversation', importance=0.5, metadata=None, valid_until=None, scope='session', extract_entities=False, extract=False) -> str": "Store a memory. Returns memory_id.",
        "recall(query, top_k=5, *, from_date=None, to_date=None, source=None, topic=None, author_id=None, author_type=None, channel_id=None, temporal_weight=0.0, query_time=None, temporal_halflife=None, vec_weight=None, fts_weight=None, importance_weight=None) -> List[Dict]": "Hybrid search across working+episodic memory.",
        "get_context(limit=10) -> List[Dict]": "Get recent working memory for prompt injection.",
        "get_stats(author_id=None, author_type=None, channel_id=None) -> Dict": "Memory stats (legacy+BEAM).",
        "forget(memory_id) -> bool": "Delete a memory.",
        "update(memory_id, content=None, importance=None) -> bool": "Update an existing memory.",
        "invalidate(memory_id, replacement_id=None) -> bool": "Mark memory as expired/superseded.",
        "sleep(dry_run=False) -> Dict": "Consolidate old working memory into episodic (current session).",
        "sleep_all_sessions(dry_run=False) -> Dict": "Consolidate across all sessions.",
        "scratchpad_write(content) -> str": "Write to scratchpad. Returns pad_id.",
        "scratchpad_read() -> List[Dict]": "Read scratchpad entries.",
        "scratchpad_clear()": "Clear scratchpad.",
        "consolidation_log(limit=10) -> List[Dict]": "Get consolidation history.",
        "export_to_file(output_path) -> Dict": "Export all data to JSON file.",
        "import_from_file(input_path, force=False) -> Dict": "Import from JSON file.",
        "enable_streaming() -> Mnemosyne": "Enable event streaming.",
        "compress(content, method='auto') -> Tuple[str, CompressionStats]": "Compress memory content.",
        "decompress(content, method='dict') -> str": "Decompress memory content.",
        "compress_memories(memories, method='auto')": "Compress batch of memories.",
        "detect_patterns(memories=None) -> list": "Detect patterns in memories.",
        "summarize_patterns(memories=None) -> dict": "Summarize detected patterns.",
        "get_all_memories() -> List[Dict]": "Get all working+episodic rows for analysis.",
        "sync_to(peer_id, table='working_memory') -> dict": "Compute delta sync.",
        "sync_from(peer_id, delta, table='working_memory') -> dict": "Apply delta sync."
      }
    },

    "BeamMemory (mnemosyne.core.beam.BeamMemory)": {
      "description": "BEAM architecture core — working_memory, episodic_memory, scratchpad tables.",
      "constructor": "BeamMemory(session_id='default', db_path=None, author_id=None, author_type=None, channel_id=None, use_cloud=False, event_emitter=None)",
      "attributes": ["session_id", "author_id", "author_type", "channel_id", "db_path", "conn", "episodic_graph", "veracity_consolidator", "use_cloud", "_extraction_client", "_extraction_buffer", "_event_emitter"],
      "methods": {
        "remember(content, source='conversation', importance=0.5, metadata=None, valid_until=None, scope='session', memory_id=None, extract_entities=False, extract=False, veracity='unknown') -> str": "Store to working_memory with dedup. Returns memory_id.",
        "remember_batch(items) -> List[str]": "Batch insert into working_memory.",
        "get_context(limit=10) -> List[Dict]": "Get working_memory for prompt injection (global first, then importance+recency).",
        "invalidate(memory_id, replacement_id=None) -> bool": "Mark memory as invalid in working_memory or episodic_memory.",
        "get_working_stats(author_id=None, author_type=None, channel_id=None) -> Dict": "Working memory stats with identity filters.",
        "get_global_working_stats() -> Dict": "DEPRECATED. Use get_working_stats().",
        "update_working(memory_id, content=None, importance=None) -> bool": "Update working_memory entry.",
        "forget_working(memory_id) -> bool": "Delete from working_memory.",
        "consolidate_to_episodic(summary, source_wm_ids, source='consolidation', importance=0.6, metadata=None, valid_until=None, scope='session') -> str": "Store consolidated summary in episodic_memory.",
        "recall(query, top_k=40, *, from_date=None, to_date=None, source=None, topic=None, author_id=None, author_type=None, channel_id=None, veracity=None, memory_type=None, temporal_weight=0.0, query_time=None, temporal_halflife=None, vec_weight=None, fts_weight=None, importance_weight=None) -> List[Dict]": "Hybrid recall (FTS5+vec+keyword+entity+fact+binary).",
        "fact_recall(query, top_k=30) -> List[Dict]": "Search facts table (LLM-extracted structured knowledge).",
        "format_context(results, format='bullet') -> str": "Format recall results as context for LLM injection. Supports 'bullet' and 'json'.",
        "get_episodic_stats(author_id=None, author_type=None, channel_id=None) -> Dict": "Episodic memory stats with identity filters.",
        "scratchpad_write(content) -> str": "Write/upsert scratchpad entry.",
        "scratchpad_read() -> List[Dict]": "Read scratchpad entries.",
        "scratchpad_clear()": "Clear scratchpad.",
        "degrade_episodic(dry_run=False) -> Dict": "Tiered episodic degradation (1→2→3).",
        "sleep(dry_run=False) -> Dict": "Consolidation cycle (session-scoped).",
        "sleep_all_sessions(dry_run=False) -> Dict": "Consolidate across all sessions.",
        "get_consolidation_log(limit=10) -> List[Dict]": "Get consolidation history.",
        "get_contaminated(limit=50, min_importance=0.0) -> List[Dict]": "Return potentially contaminated memories.",
        "export_to_dict() -> Dict": "Export BEAM data to dict.",
        "import_from_dict(data, force=False) -> Dict": "Import BEAM data from dict."
      }
    },

    "BinaryVectorStore (mnemosyne.core.binary_vectors.BinaryVectorStore)": {
      "description": "SQLite-native binary vector storage with deterministic retrieval (32x compression via MIB).",
      "constructor": "BinaryVectorStore(db_path=None, table_name='binary_vectors', conn=None)",
      "static_methods": ["maximally_informative_binarization(embedding) -> bytes", "hamming_distance(binary_a, binary_b) -> int", "information_theoretic_score(distance, dim=384) -> float"],
      "methods": ["store_vector(memory_id, embedding)", "search(query_embedding, top_k=10) -> List[Dict]", "search_batch(query_embeddings, top_k=10) -> List[List[Dict]]", "delete_vector(memory_id)", "get_stats() -> Dict", "close()"]
    },

    "FastBinarySearch (mnemosyne.core.binary_vectors.FastBinarySearch)": {
      "description": "Optimized binary search with numpy batching for high-throughput.",
      "constructor": "FastBinarySearch(binary_vectors: Dict[str, bytes])",
      "methods": ["search(query_binary, top_k=10) -> List[Dict]"]
    },

    "PolyphonicRecallEngine (mnemosyne.core.polyphonic_recall.PolyphonicRecallEngine)": {
      "description": "4-voice parallel retrieval: vector, graph, fact, temporal with RRF fusion.",
      "constructor": "PolyphonicRecallEngine(db_path=None)",
      "attributes": ["voice_weights", "vector_store", "graph", "consolidator"],
      "methods": ["recall(query, query_embedding=None, top_k=10, context_budget=4000) -> List[PolyphonicResult]", "get_stats() -> Dict", "close()"]
    },

    "TripleStore (mnemosyne.core.triples.TripleStore)": {
      "description": "Temporal knowledge graph. Tracks when facts were true, contradiction detection.",
      "constructor": "TripleStore(db_path=None)",
      "methods": ["add(subject, predicate, object, valid_from=None, source='inferred', confidence=1.0) -> int", "query(subject=None, predicate=None, object=None, as_of=None) -> List[Dict]", "get_distinct_objects(predicate) -> List[str]", "query_by_predicate(predicate, object=None) -> List[Dict]", "add_facts(memory_id, facts, source='inferred', confidence=0.5)", "export_all() -> List[Dict]", "import_all(triples, force=False) -> Dict"]
    },

    "EpisodicGraph (mnemosyne.core.episodic_graph.EpisodicGraph)": {
      "description": "Gist+Fact graph with nodes, edges, temporal qualifiers. Zero LLM calls.",
      "constructor": "EpisodicGraph(db_path=None, conn=None)",
      "methods": ["extract_gist(content, memory_id) -> Gist", "store_gist(gist, memory_id)", "extract_facts(content, memory_id) -> List[Fact]", "store_fact(fact, memory_id)", "add_edge(edge)", "find_gists_by_participant(entity) -> List[Gist]", "find_facts_by_subject(subject) -> List[Fact]", "get_stats() -> Dict", "close()"]
    },

    "VeracityConsolidator (mnemosyne.core.veracity_consolidation.VeracityConsolidator)": {
      "description": "Bayesian confidence consolidation with conflict detection.",
      "constructor": "VeracityConsolidator(db_path=None, conn=None)",
      "methods": ["consolidate_fact(subject, predicate, object, veracity, source) -> ConsolidatedFact", "get_consolidated_facts(subject=None, min_confidence=0.0) -> List[ConsolidatedFact]", "get_stats() -> Dict", "close()"]
    },

    "BankManager (mnemosyne.core.banks.BankManager)": {
      "description": "Named memory banks with per-bank SQLite isolation.",
      "constructor": "BankManager(data_dir=None)",
      "methods": ["create_bank(name) -> Path", "delete_bank(name, force=False) -> bool", "list_banks() -> List[str]", "bank_exists(name) -> bool", "get_bank_db_path(name) -> Path", "rename_bank(old_name, new_name) -> Path", "get_bank_stats(name) -> dict"]
    },

    "MemoryStream (mnemosyne.core.streaming.MemoryStream)": {
      "description": "Real-time event stream for memory operations. Thread-safe.",
      "constructor": "MemoryStream(max_buffer=1000)",
      "methods": ["on(event_type, callback)", "on_any(callback)", "off(event_type, callback)", "off_any(callback)", "emit(event)", "listen(event_types=None) -> Iterator[MemoryEvent]", "get_buffer(event_types=None, since=None) -> List[MemoryEvent]", "clear_buffer()"]
    },

    "DeltaSync (mnemosyne.core.streaming.DeltaSync)": {
      "description": "Incremental memory synchronization between Mnemosyne instances.",
      "constructor": "DeltaSync(mnemosyne_instance, checkpoint_dir=None)",
      "methods": ["get_checkpoint(peer_id) -> Optional[SyncCheckpoint]", "set_checkpoint(peer_id, checkpoint)", "compute_delta(peer_id, table='working_memory') -> List[Dict]", "apply_delta(peer_id, delta, table='working_memory') -> Dict", "sync_to(peer_id, table='working_memory') -> Dict", "sync_from(peer_id, delta, table='working_memory') -> Dict"]
    },

    "MemoryCompressor (mnemosyne.core.patterns.MemoryCompressor)": {
      "description": "Compress memory content via dict, RLE, or semantic strategies.",
      "constructor": "MemoryCompressor(dictionary=None)",
      "methods": ["compress(content, method='auto') -> Tuple[str, CompressionStats]", "decompress(content, method='dict') -> str", "compress_batch(memories, method='auto') -> Tuple[List[str], CompressionStats]"]
    },

    "PatternDetector (mnemosyne.core.patterns.PatternDetector)": {
      "description": "Detect recurring patterns in memories (temporal, content, sequence).",
      "constructor": "PatternDetector()",
      "methods": ["detect_all(memories) -> List[DetectedPattern]", "summarize_patterns(memories) -> Dict"]
    },

    "PluginManager (mnemosyne.core.plugins.PluginManager)": {
      "description": "Register, load, and manage Mnemosyne plugins.",
      "constructor": "PluginManager(plugin_dir=None)",
      "methods": ["register_plugin(name, plugin_class)", "load_plugin(name, config=None) -> MnemosynePlugin", "unload_plugin(name)", "list_plugins() -> List[Dict]", "get_plugin(name) -> Optional[MnemosynePlugin]", "is_loaded(name) -> bool", "is_registered(name) -> bool", "load_all(configs=None) -> List[MnemosynePlugin]", "unload_all()", "discover_plugins() -> List[str]", "notify_remember(memory)", "notify_recall(memory)", "notify_consolidate(summary)", "notify_invalidate(memory_id)"]
    },

    "MnemosynePlugin (mnemosyne.core.plugins.MnemosynePlugin)": {
      "description": "Abstract base class for all Mnemosyne plugins.",
      "abstract_methods": ["on_remember(memory)", "on_recall(memory)", "on_consolidate(summary)", "on_invalidate(memory_id)"],
      "concrete_methods": ["initialize()", "shutdown()", "to_dict()"]
    },

    "LoggingPlugin (mnemosyne.core.plugins.LoggingPlugin)": {
      "description": "Built-in plugin that logs all memory operations.",
      "methods": ["get_log() -> List[Dict]", "clear_log()"]
    },

    "MetricsPlugin (mnemosyne.core.plugins.MetricsPlugin)": {
      "description": "Built-in plugin that collects performance metrics.",
      "methods": ["record_timing(event, duration_ms)", "get_counters() -> Dict", "get_timings(event) -> List[float]", "get_average_timing(event) -> Optional[float]", "reset()", "get_summary() -> Dict"]
    },

    "FilterPlugin (mnemosyne.core.plugins.FilterPlugin)": {
      "description": "Built-in plugin that filters memories based on custom rules.",
      "methods": ["add_rule(rule)", "remove_rule(rule)", "clear_rules()", "get_blocked() -> List[Dict]", "is_blocked(memory_id) -> bool"]
    },

    "LLMBackend (mnemosyne.core.llm_backends.LLMBackend)": {
      "description": "Protocol for host-provided LLM completion endpoint.",
      "methods": ["complete(prompt, *, max_tokens, temperature, timeout, provider=None, model=None) -> Optional[str]"]
    },

    "CallableLLMBackend (mnemosyne.core.llm_backends.CallableLLMBackend)": {
      "description": "Wraps a callable as LLMBackend. For tests/one-off callers."
    },

    "BaseImporter (mnemosyne.core.importers.base.BaseImporter)": {
      "description": "Abstract base class for memory provider importers.",
      "abstract_methods": ["extract(**kwargs) -> List[Dict]", "transform(raw_data) -> List[Dict]", "validate(items) -> List[Dict]"],
      "concrete_methods": ["run(mnemosyne, dry_run=False, session_id=None, channel_id=None) -> ImporterResult"]
    },

    "ImporterResult (mnemosyne.core.importers.base.ImporterResult)": {
      "description": "Result dataclass for import operations.",
      "fields": ["provider", "total", "imported", "skipped", "failed", "errors", "memory_ids", "started_at", "finished_at"],
      "methods": ["to_dict()", "to_json()"]
    },

    "Mem0Importer (mnemosyne.core.importers.mem0.Mem0Importer)": {
      "description": "Imports from Mem0 cloud/self-hosted API."
    },

    "LettaImporter (mnemosyne.core.importers.letta.LettaImporter)": {
      "description": "Imports from Letta (formerly MemGPT) AgentFile format."
    },

    "ZepImporter (mnemosyne.core.importers.zep.ZepImporter)": {
      "description": "Imports from Zep enterprise temporal knowledge graph."
    },

    "CogneeImporter (mnemosyne.core.importers.cognee.CogneeImporter)": {
      "description": "Imports from Cognee graph memory (Kùzu + LanceDB + SQLite)."
    },

    "HonchoImporter (mnemosyne.core.importers.honcho.HonchoImporter)": {
      "description": "Imports from Honcho entity-centric memory."
    },

    "SuperMemoryImporter (mnemosyne.core.importers.supermemory.SuperMemoryImporter)": {
      "description": "Imports from SuperMemory cloud API."
    },

    "HindsightImporter (mnemosyne.core.importers.hindsight.HindsightImporter)": {
      "description": "Imports from Hindsight/Hermes memory provider."
    },

    "AgenticImporter (mnemosyne.core.importers.agentic.AgenticImporter)": {
      "description": "AI-guided migration import flow."
    },

    "MnemosyneMemoryProvider (hermes_memory_provider.MnemosyneMemoryProvider)": {
      "description": "Hermes MemoryProvider integration — system prompt injection, prefetch, sync, tool dispatch.",
      "constructor": "MnemosyneMemoryProvider()",
      "properties": ["name", "SESSION_END_SLEEP_TIMEOUT_SECONDS"],
      "methods": ["is_available() -> bool", "initialize(session_id, **kwargs)", "system_prompt_block() -> str", "prefetch(query, *, session_id='') -> str", "queue_prefetch(query, *, session_id='')", "sync_turn(user_content, assistant_content, *, session_id='')", "get_tool_schemas() -> List[Dict]", "handle_tool_call(tool_name, args, **kwargs) -> str", "get_config_schema() -> List[Dict]", "save_config(values, hermes_home)", "on_session_end(session_id, **kwargs)", "shutdown(session_id)", "on_session_replay(session_id, history)",
        "_handle_remember(args) -> str", "_handle_recall(args) -> str", "_handle_sleep(args) -> str", "_handle_stats(args) -> str", "_handle_invalidate(args) -> str", "_handle_triple_add(args) -> str", "_handle_triple_query(args) -> str"]
    }
  },

  "dataclasses": {
    "MemoryEvent": {"fields": ["event_type", "memory_id", "timestamp", "session_id", "content", "source", "importance", "metadata", "delta"], "methods": ["to_dict()", "to_json()", "from_dict(data)"]},
    "SyncCheckpoint": {"fields": ["peer_id", "last_sync_at", "last_memory_id", "last_rowid"], "methods": ["to_dict()", "to_json()"]},
    "CompressionStats": {"fields": ["original_size", "compressed_size", "ratio", "method", "patterns_found", "memories_compressed"], "properties": ["savings_percent"]},
    "DetectedPattern": {"fields": ["pattern_type", "description", "confidence", "examples", "frequency"]},
    "Gist": {"fields": ["id", "text", "timestamp", "participants", "location", "emotion", "time_scope"]},
    "Fact": {"fields": ["id", "subject", "predicate", "object", "timestamp", "confidence", "temporal_qualifier"]},
    "GraphEdge": {"fields": ["source", "target", "edge_type", "weight", "timestamp"]},
    "ConsolidatedFact": {"fields": ["subject", "predicate", "object", "confidence", "mention_count", "first_seen", "last_seen", "sources", "veracity", "superseded"]},
    "RecallResult": {"fields": ["memory_id", "score", "voice", "metadata"]},
    "PolyphonicResult": {"fields": ["memory_id", "combined_score", "voice_scores", "metadata"]},
    "TypeMatch": {"fields": ["memory_type", "confidence", "matched_pattern", "priority"]},
    "ImporterResult": {"fields": ["provider", "total", "imported", "skipped", "failed", "errors", "memory_ids", "started_at", "finished_at"], "methods": ["to_dict()", "to_json()"]}
  },

  "enums": {
    "EventType": ["MEMORY_ADDED", "MEMORY_RECALLED", "MEMORY_INVALIDATED", "MEMORY_CONSOLIDATED", "MEMORY_UPDATED"],
    "MemoryType": ["FACT", "PREFERENCE", "DECISION", "COMMITMENT", "GOAL", "EVENT", "INSTRUCTION", "RELATIONSHIP", "CONTEXT", "LEARNING", "OBSERVATION", "ERROR", "ARTIFACT", "UNKNOWN"],
    "VERACITY_WEIGHTS": {"stated": 1.0, "inferred": 0.7, "tool": 0.5, "imported": 0.6, "unknown": 0.8}
  },

  "cli_commands": {
    "mnemosyne": {
      "subcommands": {
        "store <content> [source] [importance]": "Store a memory",
        "remember <content> [source] [importance]": "Alias for store",
        "recall <query> [top_k]": "Search memories",
        "search <query> [top_k]": "Alias for recall",
        "update <memory_id> <new_content> [importance]": "Update a memory",
        "edit <memory_id> <new_content> [importance]": "Alias for update",
        "delete <memory_id>": "Delete a memory",
        "forget <memory_id>": "Alias for delete",
        "stats": "Show memory statistics",
        "sleep": "Run consolidation cycle",
        "consolidate": "Alias for sleep",
        "diagnose": "Run PII-safe diagnostics",
        "export [file.json]": "Export memories to JSON",
        "import <file.json>": "Import memories from JSON",
        "import-hindsight <file.json|base_url> [bank]": "Import Hindsight memories",
        "mcp [--transport sse] [--port 8080] [--bank NAME]": "Start MCP server",
        "bank list|create|delete [name]": "Manage memory banks"
      }
    },
    "hermes_memory_provider subcommands (hermes mnemosyne)": {
      "stats [--global]": "Show memory statistics",
      "sleep [--all-sessions] [--dry-run]": "Run consolidation cycle",
      "version": "Show Mnemosyne version",
      "inspect [query] [--limit N]": "Search memories",
      "clear": "Clear scratchpad",
      "export --output <path>": "Export all memories",
      "import --input <path> [--force] [--from <provider> --api-key <key>] [--list-providers] [--agentic] [--generate-script] [--dry-run] [--bank NAME]": "Import from file or provider"
    }
  },

  "mcp_tools": {
    "mnemosyne_remember": {
      "description": "Store a memory. Supports entity extraction, fact extraction, and bank selection.",
      "parameters": {"content": "str (required)", "source": "str", "importance": "number", "metadata": "object", "extract_entities": "bool", "extract": "bool", "author_id": "str", "author_type": "str", "channel_id": "str", "bank": "str"},
      "returns": {"status": "stored", "memory_id": "str", "bank": "str"}
    },
    "mnemosyne_recall": {
      "description": "Hybrid search (vector+FTS+importance+temporal). Configurable weights.",
      "parameters": {"query": "str (required)", "top_k": "int", "bank": "str", "temporal_weight": "number", "query_time": "str", "vec_weight": "number", "fts_weight": "number", "importance_weight": "number", "author_id": "str", "author_type": "str", "channel_id": "str"},
      "returns": {"status": "ok", "count": "int", "results": "list", "bank": "str"}
    },
    "mnemosyne_sleep": {
      "description": "Run consolidation sleep cycle.",
      "parameters": {"dry_run": "bool", "bank": "str"},
      "returns": {"status": "ok", "dry_run": "bool", "result": "dict", "bank": "str"}
    },
    "mnemosyne_scratchpad_read": {
      "description": "Read agent scratchpad.",
      "parameters": {"bank": "str"},
      "returns": {"status": "ok", "count": "int", "entries": "list", "bank": "str"}
    },
    "mnemosyne_scratchpad_write": {
      "description": "Write to agent scratchpad.",
      "parameters": {"content": "str (required)", "bank": "str"},
      "returns": {"status": "stored", "entry_id": "str", "bank": "str"}
    },
    "mnemosyne_get_stats": {
      "description": "Get memory system statistics.",
      "parameters": {"bank": "str"},
      "returns": {"status": "ok", "stats": "dict", "bank": "str"}
    }
  },

  "hermes_plugin_tools": {
    "provided_by": "hermes_plugin/__init__.py",
    "tools": ["mnemosyne_remember", "mnemosyne_recall", "mnemosyne_stats", "mnemosyne_triple_add", "mnemosyne_triple_query", "mnemosyne_sleep", "mnemosyne_scratchpad_write", "mnemosyne_scratchpad_read", "mnemosyne_scratchpad_clear", "mnemosyne_invalidate", "mnemosyne_export", "mnemosyne_update", "mnemosyne_forget", "mnemosyne_import", "mnemosyne_diagnose"],
    "hooks": ["pre_llm_call", "on_session_start", "post_tool_call"],
    "schemas": {
      "mnemosyne_remember": {"required": ["content"], "properties": ["content", "importance", "source", "valid_until", "scope", "extract_entities", "extract", "author_id", "author_type", "channel_id"]},
      "mnemosyne_recall": {"required": ["query"], "properties": ["query", "top_k", "temporal_weight", "query_time", "temporal_halflife", "vec_weight", "fts_weight", "importance_weight", "author_id", "author_type", "channel_id"]},
      "mnemosyne_stats": {"properties": {}},
