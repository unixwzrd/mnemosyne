  "database_schema": {
    "tables": {
      "memories": "Legacy memories table (id, content, source, timestamp, session_id, importance, metadata_json, created_at)",
      "memory_embeddings": "Legacy embedding fallback (memory_id, embedding_json, model, created_at)",
      "working_memory": "BEAM hot context (id, content, source, timestamp, session_id, importance, metadata_json, valid_until, superseded_by, scope, recall_count, last_recalled, author_id, author_type, channel_id, veracity, memory_type, created_at)",
      "episodic_memory": "BEAM long-term (rowid, id, content, source, timestamp, session_id, importance, metadata_json, summary_of, valid_until, superseded_by, scope, recall_count, last_recalled, author_id, author_type, channel_id, veracity, memory_type, tier, degraded_at, binary_vector, created_at)",
      "scratchpad": "Temporary workspace (id, content, session_id, created_at, updated_at)",
      "consolidation_log": "Sleep history (id, session_id, items_consolidated, summary_preview, created_at)",
      "triples": "Temporal knowledge graph (id, subject, predicate, object, valid_from, valid_until, source, confidence, created_at)",
      "facts": "LLM-extracted structured knowledge (fact_id, session_id, subject, predicate, object, timestamp, source_msg_id, confidence, created_at)",
      "gists": "Episode summaries (id, text, timestamp, participants_json, location, emotion, time_scope, memory_id, created_at)",
      "facts": "Structured triples (id, subject, predicate, object, timestamp, confidence, source_msg_id, created_at)",
      "graph_edges": "Graph relationships (source, target, edge_type, weight, timestamp)",
      "consolidated_facts": "Veracity-consolidated facts (id, subject, predicate, object, confidence, mention_count, first_seen, last_seen, sources_json, veracity, superseded_by, created_at, updated_at)",
      "harmonic_beliefs": "SHMR harmonic beliefs (belief_id, subject, predicate, object, confidence, provenance, cluster_id, iteration, created_at, updated_at)",
      "memory_resonance_log": "SHMR resonance log (id, session_id, cluster_count, beliefs_generated, contradictions_resolved, harmony_score_avg, duration_ms, created_at)",
      "cost_entries": "Cost tracking (id, session_id, memory_count, token_count, estimated_cost_usd, model, timestamp)"
    },
    "virtual_tables": {
      "vec_episodes": "sqlite-vec vector index on episodic_memory (embedding float32|int8|bit[384])",
      "fts_episodes": "FTS5 full-text search on episodic_memory (content)",
      "fts_working": "FTS5 full-text search on working_memory (id, content)",
      "fts_facts": "FTS5 full-text search on facts (subject, predicate, object)",
      "vec_facts": "sqlite-vec on facts (embedding float32|int8|bit[384])"
    }
  },

