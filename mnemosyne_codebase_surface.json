  "architecture_phases": {
    "BEAM": "Bilevel Episodic-Associative Memory: working_memory, episodic_memory, scratchpad",
    "Phase 1 (Typed Memory)": "13-type deterministic classification (FACT, PREFERENCE, DECISION, etc.)",
    "Phase 2 (Binary Vectors)": "Moorcheh ITS — 32x compression via Maximally Informative Binarization",
    "Phase 3 (Episodic Graph)": "REMem-based gist+fact graph with time-aware edges",
    "Phase 4 (Veracity Consolidation)": "Bayesian confidence scoring with conflict resolution",
    "Phase 5 (Polyphonic Recall)": "4-voice parallel: vector, graph, fact, temporal + binary bonus",
    "Phase 8 (Streaming+Patterns)": "Event streaming, delta sync, memory compression, pattern detection",
    "SHMR": "Self-Harmonizing Memory Reasoning — continuous memory resonance and contradiction resolution",
    "NAI-0, NAI-1": "Context formatting (sandwich ordering, chat normalization)",
    "Configurable Scoring": "Per-query vec/fts/importance weight tuning with auto-normalization",
    "Tiered Degradation": "3-tier episodic aging: full→LLM-summarized→extracted compressed",
    "Memory Banks": "Per-bank SQLite isolation under data_dir/banks/<name>/",
    "Multi-Agent Identity": "author_id, author_type, channel_id filtering on all operations",
    "Host LLM Backend": "Pluggable adapter for agent-hosted LLM routing (Hermes integration)"
  }
}
